# Configuration avancée pour LinkedIn SEO Analyzer
# Copiez ce fichier vers .env et personnalisez selon vos besoins

# Paramètres de collecte
POSTS_PER_PROFILE=10
MIN_CHARS=50
SCROLL_DELAY=1.2
RANDOM_DELAY_MAX=0.8

# Paramètres d'analyse
MIN_WORD_FREQUENCY=3
TOP_TRENDS_COUNT=10
SIMILARITY_THRESHOLD=0.7

# Chemins personnalisés (optionnel)
# CUSTOM_DATA_DIR=/path/to/custom/data
# CUSTOM_OUTPUT_DIR=/path/to/custom/output
# CUSTOM_PROFILES_FILE=/path/to/custom/profiles.txt

# Mots-clés SEO supplémentaires (séparés par des virgules)
ADDITIONAL_SEO_KEYWORDS=ia,intelligence artificielle,chatgpt,automation,machine learning

# Configuration des posts
DEFAULT_POST_COUNT=5
HASHTAGS_LIMIT=6

# Programmation automatique
ANALYSIS_DAY=wednesday
ANALYSIS_TIME=10:00
GENERATION_DAY=friday
GENERATION_TIME=15:00

# Paramètres de debug
DEBUG_MODE=false
VERBOSE_LOGGING=false
